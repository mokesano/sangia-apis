# ── Aplikasi ──────────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=false
APP_URL=https://api.sangia.org

# ── Database ──────────────────────────────────────────────────────────────────
# Driver: mysql | mariadb | pgsql
# Database akan dibuat otomatis jika belum ada
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wizdam_research
DB_USERNAME=root
DB_PASSWORD=your_secure_password
DB_CHARSET=utf8mb4

# ── CORS ──────────────────────────────────────────────────────────────────────
# Pisahkan dengan koma; harus cocok dengan origin frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://www.sangia.org

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=generate_64_character_random_string_here_and_keep_it_secret
JWT_TTL=86400

# ── ORCID OAuth2 ──────────────────────────────────────────────────────────────
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=https://www.sangia.org/auth/orcid-callback
ORCID_SANDBOX=true

# ── Sangia AI Engine (SDG classification) ────────────────────────────────────
SANGIA_API_URL=https://api.sangia.org
SANGIA_API_KEY=

# ── Scopus API ────────────────────────────────────────────────────────────────
SCOPUS_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://www.sangia.org
