# ═══════════════════════════════════════════════════════════════════════════════
# WIZDAM ECOSYSTEM — UNIFIED .env TEMPLATE
# Gunakan sebagai referensi untuk SEMUA aplikasi: wizdam-apis, wizdam-sikola,
# sdg-mapper, sdgs-analytics, sdg-mono. Setiap app hanya aktifkan setting yang relevan.
# ═══════════════════════════════════════════════════════════════════════════════

# ── SECTION 1: Aplikasi (wizdam-apis only) ────────────────────────────────────────
# Hanya digunakan oleh wizdam-apis
APP_ENV=development
APP_DEBUG=false
APP_URL=https://api.sangia.org

# ── SECTION 2: Database (SHARED — identik di SEMUA aplikasi) ──────────────────────
# Wajib di: wizdam-apis, wizdam-sikola, sdg-mapper, sdgs-analytics (opsional), sdg-mono
# Driver: mysql | mariadb | pgsql
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wizdam_ecosystem
DB_USERNAME=root
DB_PASSWORD=your_secure_password
DB_CHARSET=utf8mb4

# ── SECTION 3: API Key Authentication (SHARED — IDENTICAL di SEMUA aplikasi) ──────
# WAJIB SAMA di: wizdam-apis, wizdam-sikola, sdg-mapper, sdgs-analytics, sdg-mono
# Setiap app bisa generate keys; wizdam-apis memvalidasi dengan secret yang sama.
# Generate once: openssl rand -hex 32
WIZDAM_SHARED_SECRET=generate_64_character_random_hex_string_here

# ── SECTION 4: Rate Limiting (wizdam-apis only) ────────────────────────────────────
# Hanya digunakan oleh wizdam-apis
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# ── SECTION 5: CORS (wizdam-apis only) ─────────────────────────────────────────────
# Hanya digunakan oleh wizdam-apis untuk validasi origin frontend
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://www.sangia.org

# ── SECTION 6: JWT (wizdam-apis only) ──────────────────────────────────────────────
# Hanya digunakan oleh wizdam-apis jika menggunakan JWT auth
JWT_SECRET=generate_64_character_random_string_here_and_keep_it_secret
JWT_TTL=86400

# ── SECTION 7: External APIs (SHARED — di apps yang membutuhkan) ───────────────────

# ORCID OAuth2 (digunakan oleh: wizdam-apis, wizdam-sikola, sdg-mapper)
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=https://www.sangia.org/auth/orcid-callback
ORCID_SANDBOX=true

# Scopus API (digunakan oleh: wizdam-apis, wizard-sikola, sdg-mapper)
SCOPUS_API_KEY=

# Semantic Scholar API (digunakan oleh: wizdam-apis)
# Official API key untuk higher rate limits. Get at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# PubMed / NCBI E-utilities (digunakan oleh: wizdam-apis)
# API key raises rate limit dari 3 req/s ke 10 req/s. Get at: https://www.ncbi.nlm.nih.gov/account/
PUBMED_API_KEY=

# OpenAlex API (digunakan oleh: wizdam-apis)
# No API key required. Email used untuk polite pool (faster responses).
OPENALEX_MAILTO=api@sangia.org

# Crossref API (digunakan oleh: wizdam-apis)
# No API key required untuk basic access
CROSSREF_MAILTO=api@sangia.org

# ── SECTION 8: Frontend URLs (SHARED di frontend apps) ────────────────────────────

# Digunakan oleh: sdg-mapper, sdgs-analytics, wizdam-sikola (untuk redirect/links)
FRONTEND_URL=https://www.sangia.org
REACT_APP_API_URL=https://api.sangia.org
REACT_APP_API_KEY=wz_your_client_id_here

# ── SECTION 9: Internal APIs (Aplikasi saling memanggil) ──────────────────────────

# Digunakan oleh: wizdam-sikola, sdg-mapper, sdgs-analytics untuk call wizdam-apis
WIZDAM_API_URL=https://api.sangia.org
WIZDAM_API_KEY=wz_app_id_generated_in_wizdam_sikola

# ═══════════════════════════════════════════════════════════════════════════════
# NOTES UNTUK SETIAP APLIKASI:
# ═══════════════════════════════════════════════════════════════════════════════
# wizdam-apis:
#   ✓ SECTION 1 (APP_*), SECTION 2 (DB_*), SECTION 3 (WIZDAM_SHARED_SECRET),
#     SECTION 4 (RATE_LIMIT_*), SECTION 5 (CORS_*), SECTION 6 (JWT_*),
#     SECTION 7 (semua external API keys), SECTION 8 (FRONTEND_URL)
#
# wizdam-sikola (OJS):
#   ✓ SECTION 2 (DB_*), SECTION 3 (WIZDAM_SHARED_SECRET),
#     SECTION 7 (ORCID_*, SCOPUS_API_KEY, OPENALEX_MAILTO),
#     SECTION 8 (FRONTEND_URL, REACT_APP_*), SECTION 9 (WIZDAM_API_*)
#
# sdg-mapper (React + PHP):
#   ✓ SECTION 2 (DB_*), SECTION 3 (WIZDAM_SHARED_SECRET),
#     SECTION 7 (ORCID_*, SCOPUS_API_KEY, OPENALEX_MAILTO),
#     SECTION 8 (FRONTEND_URL, REACT_APP_*), SECTION 9 (WIZDAM_API_*)
#
# sdgs-analytics (React Dashboard):
#   ✓ SECTION 2 (DB_*), SECTION 3 (WIZDAM_SHARED_SECRET),
#     SECTION 8 (FRONTEND_URL, REACT_APP_*), SECTION 9 (WIZDAM_API_*)
#
# sdg-mono (Legacy PHP):
#   ✓ SECTION 2 (DB_*), SECTION 3 (WIZDAM_SHARED_SECRET),
#     SECTION 9 (WIZDAM_API_*)
# ═══════════════════════════════════════════════════════════════════════════════

