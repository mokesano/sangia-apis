{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://api.sangia.org/v1/schema/sangia-apis.schema.json",
  "title": "Sangia APIs Response Contract",
  "version": "1.0.0",
  "description": "Shared JSON Schema antara sangia-apis, sangia-sikola, dan sdgs-mapper. Perubahan di sini harus diikuti oleh semua consumer.",

  "definitions": {

    "ApiEnvelope": {
      "type": "object",
      "description": "Wrapper standar SEMUA response dari api.sangia.org",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error", "pending"],
          "description": "Status response. 'pending' digunakan untuk async job."
        },
        "message": {
          "type": "string",
          "description": "Pesan opsional, wajib ada saat status=error"
        },
        "data": {
          "description": "Payload utama, ada saat status=success"
        },
        "error_code": {
          "type": "string",
          "description": "Kode error internal, contoh: ORCID_NOT_FOUND, RATE_LIMITED"
        },
        "api_version": {
          "type": "string",
          "description": "Versi API yang merespons, contoh: 1.0.0"
        }
      }
    },

    "ImpactMetrics": {
      "type": "object",
      "description": "Hasil dari POST /api/v1/impact/calculate",
      "required": ["h_index", "citations", "impact_score"],
      "properties": {
        "h_index": {
          "type": "integer",
          "minimum": 0
        },
        "citations": {
          "type": "integer",
          "minimum": 0
        },
        "impact_score": {
          "type": "number",
          "minimum": 0
        },
        "citation_trend": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["year", "count"],
            "properties": {
              "year": { "type": "integer" },
              "count": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "sangia_impact_score": {
          "type": "number",
          "minimum": 0,
          "description": "Skor khusus Sangia, berbeda dari impact_score standar"
        }
      }
    },

    "SdgClassification": {
      "type": "object",
      "description": "Hasil klasifikasi SDG untuk satu artikel",
      "required": ["sdg_id", "confidence"],
      "properties": {
        "sdg_id": {
          "type": "string",
          "pattern": "^SDG([1-9]|1[0-7])$",
          "description": "Contoh: SDG1, SDG17"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Kalimat/frasa pendukung klasifikasi"
        }
      }
    },

    "WorkItem": {
      "type": "object",
      "description": "Satu publikasi/artikel",
      "required": ["title"],
      "properties": {
        "title": { "type": "string" },
        "doi": { "type": ["string", "null"] },
        "year": { "type": ["integer", "null"] },
        "sdg_classifications": {
          "type": "array",
          "items": { "$ref": "#/definitions/SdgClassification" }
        },
        "confidence_scores": {
          "type": "object",
          "description": "Shorthand map: { SDG3: 0.92, SDG6: 0.78 }",
          "additionalProperties": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },

    "ResearcherInfo": {
      "type": "object",
      "required": ["name", "orcid"],
      "properties": {
        "name": { "type": "string" },
        "orcid": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{4}-\\d{4}-\\d{3}[\\dX]$"
        },
        "affiliation": { "type": ["string", "null"] },
        "country": { "type": ["string", "null"] },
        "avatar_url": { "type": ["string", "null"] }
      }
    },

    "SdgSummaryItem": {
      "type": "object",
      "required": ["work_count", "avg_confidence"],
      "properties": {
        "work_count": { "type": "integer", "minimum": 0 },
        "avg_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "percentage": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },

    "OrcidAnalysisResponse": {
      "description": "Response dari POST /api/v1/analyze/orcid atau GET /api/researcher_profile.php",
      "allOf": [
        { "$ref": "#/definitions/ApiEnvelope" },
        {
          "properties": {
            "data": {
              "type": "object",
              "required": ["researcher_info", "sdg_summary", "works"],
              "properties": {
                "researcher_info": { "$ref": "#/definitions/ResearcherInfo" },
                "impact_metrics": { "$ref": "#/definitions/ImpactMetrics" },
                "sdg_summary": {
                  "type": "object",
                  "description": "Key adalah SDG ID (SDG1..SDG17)",
                  "additionalProperties": { "$ref": "#/definitions/SdgSummaryItem" }
                },
                "works": {
                  "type": "array",
                  "items": { "$ref": "#/definitions/WorkItem" }
                },
                "total_works": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      ]
    },

    "DoiAnalysisResponse": {
      "description": "Response dari POST /api/v1/analyze/doi",
      "allOf": [
        { "$ref": "#/definitions/ApiEnvelope" },
        {
          "properties": {
            "data": {
              "type": "object",
              "required": ["work"],
              "properties": {
                "work": { "$ref": "#/definitions/WorkItem" },
                "journal": {
                  "type": ["object", "null"],
                  "properties": {
                    "name": { "type": "string" },
                    "issn": { "type": ["string", "null"] },
                    "quartile": { "type": ["string", "null"] }
                  }
                }
              }
            }
          }
        }
      ]
    },

    "ImpactCalculateResponse": {
      "description": "Response dari POST /api/v1/impact/calculate",
      "allOf": [
        { "$ref": "#/definitions/ApiEnvelope" },
        {
          "properties": {
            "data": { "$ref": "#/definitions/ImpactMetrics" }
          }
        }
      ]
    },

    "AsyncJobResponse": {
      "description": "Response ketika proses di-queue (mode async)",
      "allOf": [
        { "$ref": "#/definitions/ApiEnvelope" },
        {
          "properties": {
            "data": {
              "type": "object",
              "required": ["job_id", "status"],
              "properties": {
                "job_id": { "type": "string" },
                "status": {
                  "type": "string",
                  "enum": ["pending", "running", "completed", "failed"]
                },
                "progress": {
                  "type": ["integer", "null"],
                  "minimum": 0,
                  "maximum": 100
                },
                "result_url": { "type": ["string", "null"] }
              }
            }
          }
        }
      ]
    }
  }
}