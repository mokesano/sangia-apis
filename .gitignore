# ---------------------------------------------------------------
# WIZDAM APIS - .GITIGNORE CONFIGURATION
# Optimized for Laravel/CodeIgniter Hybrid & Unit Testing
# ---------------------------------------------------------------

# 1. Environment & secrets
.env
.env.*
.env.*.local
!.env.example
WIZDAM_SHARED_SECRET=
SEMANTIC_SCHOLAR_API_KEY=
DIMENSION_API_KEY=

# 2. Composer vendor (we commit library/ intentionally)
vendor/
/composer.lock

# 3. FRAMEWORK CACHE & LOGS
/storage/*.key
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/logs/*
!storage/framework/cache/.gitignore
!storage/framework/sessions/.gitignore
!storage/framework/views/.gitignore
!storage/logs/.gitignore

# 4. Runtime — cache and logs never belong in version control
writable/
logs/
*.log
/writable/cache/
/writable/logs/
/writable/session/
/writable/uploads/
!writable/uploads/.gitignore

# 5. TESTING ARTIFACTS
/tests/_output/
/tests/_support/_generated/
.coverage
coverage.xml
.phpunit.result.cache
test-results/
*.sqlite
*.db
tests/database.sqlite

# 6. OS & IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*.sublime-project
*.sublime-workspace
*~
.project
.classpath
.settings/

# 7. BUILD & TEMPORARY FILES
/tmp/
temp/
*.tmp
*.bak
*.old

# 8. PHP build artifacts
*.phar

# 9. DOCUMENTATION BUILD
/docs/_build/